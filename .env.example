# ContentForge config — all API keys are optional
# Local AI (Ollama) works with no keys at all.

# Cloud AI fallback (if Ollama is down)
# Sign up: https://free.ai (free tier: 30k tokens/day)
# FREEAI_API_KEY=

# Web search fallback (no AI)
# Sign up: https://brave.com/search/api/ (free: 2000 queries/month)
# BRAVE_API_KEY=

# Stock footage from Pexels (best quality, 200 downloads/month free)
# PEXELS_API_KEY=

# Stock footage from Pixabay (100 downloads/day free)
# PIXABAY_API_KEY=

# YouTube via yt-dlp needs no API key and always works as fallback
